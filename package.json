    "e2e": "start-server-and-test \"vite --host 127.0.0.1 --port 5173\" http://127.0.0.1:5173 \"node scripts/run-cypress.mjs run --e2e\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "react": "^19.2.7",
